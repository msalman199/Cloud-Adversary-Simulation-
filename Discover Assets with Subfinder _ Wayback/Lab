Task 1: Install and Configure Subfinder
Step 1.1: Install Subfinder
# Update system packages
sudo apt update && sudo apt upgrade -y

# Install Go programming language
sudo apt install golang-go -y

# Verify Go installation
go version

# Install Subfinder
go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest

# Add Go bin to PATH
echo 'export PATH=$PATH:~/go/bin' >> ~/.bashrc
source ~/.bashrc

# Verify installation
subfinder -version
Step 1.2: Configure API Keys
# Create configuration directory
mkdir -p ~/.config/subfinder

# Create provider configuration file
cat > ~/.config/subfinder/provider-config.yaml << 'EOF'
# Add your API keys here (optional but recommended)
virustotal: []
shodan: []
github: []
censys: []
EOF

# Set permissions
chmod 600 ~/.config/subfinder/provider-config.yaml
Step 1.3: Perform Basic Subdomain Discovery
# Create working directory
mkdir ~/asset_discovery_lab
cd ~/asset_discovery_lab

# Run basic subdomain discovery
subfinder -d example.com -o subdomains.txt

# View results
cat subdomains.txt
echo "Total subdomains: $(wc -l < subdomains.txt)"
Step 1.4: Validate Active Subdomains
# Install httpx for probing
go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest

# Probe discovered subdomains
httpx -l subdomains.txt -o active_hosts.txt -status-code -title

# Display results
cat active_hosts.txt
echo "Active hosts: $(wc -l < active_hosts.txt)"
Task 2: Retrieve Historical Data with Wayback Machine
Step 2.1: Install Wayback Tools
# Install Python packages
sudo apt install python3-pip -y
pip3 install requests waybackpy

# Install waybackurls
go install github.com/tomnomnom/waybackurls@latest

# Verify installation
waybackurls --help
Step 2.2: Collect Historical URLs
# Create directory for historical data
mkdir historical_data

# Retrieve historical URLs
waybackurls example.com > historical_data/wayback_urls.txt

# Remove duplicates
sort -u historical_data/wayback_urls.txt > historical_data/unique_urls.txt

echo "Historical URLs found: $(wc -l < historical_data/unique_urls.txt)"
Step 2.3: Analyze Historical Data
# Extract interesting files
grep -E '\.(js|json|xml|config|env|bak)$' historical_data/unique_urls.txt > historical_data/interesting_files.txt

# Find API endpoints
grep -E '/(api|v1|v2|rest|graphql)/' historical_data/unique_urls.txt > historical_data/api_endpoints.txt

# Locate admin panels
grep -E '/(admin|panel|dashboard)' historical_data/unique_urls.txt > historical_data/admin_panels.txt

# Display summary
echo "Interesting files: $(wc -l < historical_data/interesting_files.txt)"
echo "API endpoints: $(wc -l < historical_data/api_endpoints.txt)"
echo "Admin panels: $(wc -l < historical_data/admin_panels.txt)"
