Task 3: Implement Workflow Security Measures
Step 3.1: Create Secure Workflow Template
Build a hardened workflow template.

cat > .github/workflows/secure-ci.yml << 'EOF'
name: Secure CI Pipeline

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

# Restrict permissions
permissions:
  contents: read
  pull-requests: read

jobs:
  test:
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v3
      with:
        persist-credentials: false
    
    - name: Set up Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.9'
    
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install pytest
    
    - name: Run tests
      run: python tests/test_app.py
    
    # Security: No secret exposure, minimal permissions
    - name: Build application
      run: python src/app.py
EOF
